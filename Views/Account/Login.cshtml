@model dynamic
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="row justify-content-center min-vh-100 align-items-center">
    <div class="col-lg-10 col-xl-9">
        <div class="elegant-card p-0 overflow-hidden border-0 shadow-lg d-flex flex-column flex-lg-row" style="min-height: 550px;">
            <!-- Simple Branding Side -->
            <div class="p-5 d-flex flex-column justify-content-center text-center text-lg-start bg-dark position-relative" style="flex: 1; border-right: 1px solid var(--border-color);">
                <div class="mb-4">
                    <a asp-controller="Home" asp-action="Index" class="navbar-brand fs-2 text-decoration-none">Soru<span>Cevap</span></a>
                </div>
                <h2 class="font-heading text-white mb-4">Hoş Geldin.</h2>
                <p class="text-muted lead mb-0">Öğrenci topluluğuna katıl ve bilginin gücünü keşfet. Senin sorun, başkasının çözümüdür.</p>
                <div class="mt-auto pt-5 d-none d-lg-block">
                    <p class="small text-muted mb-0 opacity-50">&copy; 2026 SoruCevap Platformu</p>
                </div>
            </div>

            <!-- Login Section -->
            <div class="p-5 d-flex flex-column justify-content-center" style="flex: 1.2;">
                <div class="mb-5">
                    <h3 class="font-heading neon-glow-text mb-2">OTURUM AÇ</h3>
                    <p class="text-muted small">Devam etmek için kimlik bilgilerini gir.</p>
                </div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>
                    
                    <div class="mb-4">
                        <label class="form-label small text-muted fw-bold">E-POSTA ADRESİ</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0 border-secondary border-opacity-20 text-muted"><i class="fas fa-envelope"></i></span>
                            <input name="email" type="email" class="form-control border-start-0" placeholder="ornek@okul.com" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <label class="form-label small text-muted fw-bold">ŞİFRE</label>
                            <a href="#" class="small text-muted text-decoration-none hover-neon">Şifremi Unuttum</a>
                        </div>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0 border-secondary border-opacity-20 text-muted"><i class="fas fa-lock"></i></span>
                            <input name="password" type="password" class="form-control border-start-0" placeholder="••••••••" required />
                        </div>
                    </div>

                    <button type="submit" class="btn-elegant-cyan w-100 py-3 mt-4">
                        GİRİŞ YAP <i class="fas fa-arrow-right ms-2"></i>
                    </button>
                    
                    <div class="text-center mt-5">
                        <p class="text-muted small">Hesabın yok mu? <a asp-action="Register" class="neon-glow-pink text-decoration-none fw-bold ms-2">Üye Ol</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .input-group-text { border-radius: 10px 0 0 10px; }
    .form-control { border-radius: 0 10px 10px 0; }
    .hover-neon:hover { color: var(--neon-cyan) !important; }
</style>

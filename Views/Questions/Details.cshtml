@model SoruCevap_forum_.Models.Question
@{
    ViewData["Title"] = Model.Title;
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none small hover-neon">Ana Sayfa</a></li>
        <li class="breadcrumb-item active small text-white opacity-50">Soru Detayı</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <!-- Main Question Content -->
    <div class="col-lg-12 mb-5">
        <div class="elegant-card p-5 border-0 card-cyan shadow-lg">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <span class="badge badge-neon-cyan py-1 px-3">@Model.Category?.Name</span>
                <div class="d-flex align-items-center text-muted extra-small">
                    <span class="me-3"><i class="far fa-clock me-1"></i> @Model.CreatedAt.ToString("g")</span>
                    @if (User.IsInRole("Admin"))
                    {
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bu veriyi silmek istediğinizden emin misiniz?');">
                            <button type="submit" class="btn btn-link text-danger p-0 ms-2"><i class="fas fa-trash-alt"></i></button>
                        </form>
                    }
                </div>
            </div>

            <h1 class="font-heading text-white mb-4 display-6">@Model.Title</h1>
            
            <div class="question-body fs-5 text-white opacity-75 mb-5 lh-lg font-secondary">
                @Model.Content
            </div>

            <div class="pt-4 border-top border-secondary border-opacity-10">
                <div class="d-flex align-items-center">
                    <div class="bg-dark p-2 rounded-circle me-3 border border-secondary border-opacity-20">
                         <i class="fas fa-user-circle fa-2x text-white opacity-30"></i>
                    </div>
                    <div>
                        <div class="fw-bold mb-0 text-white">@Model.User?.FullName</div>
                        <div class="extra-small neon-glow-pink font-heading">SEVİYE: @Model.User?.Level.ToUpper()</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Feedback Section -->
    <div class="col-lg-8 order-lg-1">
        <h5 class="font-heading text-white mb-4"><i class="fas fa-reply me-2 neon-glow-text"></i> Yanıtlar (@Model.Answers.Count)</h5>
        
        @if (!Model.Answers.Any())
        {
            <div class="elegant-card text-center py-5 border-dashed border-secondary bg-transparent">
                <p class="text-muted mb-0 small opacity-50">// Henüz yanıt eklenmemiş. İlk adımı sen at!</p>
            </div>
        }
        else
        {
            @foreach (var answer in Model.Answers.OrderByDescending(a => a.Likes.Count))
            {
                <div class="elegant-card mb-4 border-secondary border-opacity-10">
                    <div class="d-flex justify-content-between mb-4">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-id-badge fa-2x me-3 text-muted opacity-30"></i>
                            <div>
                                <div class="fw-bold text-white small">@answer.User?.FullName</div>
                                <div class="extra-small neon-glow-pink font-heading">@answer.User?.Level.ToUpper()</div>
                            </div>
                        </div>
                        <div class="text-center">
                            <button class="btn btn-dark border border-secondary border-opacity-20 rounded-pill px-3 like-btn" data-id="@answer.Id">
                                <i class="@(answer.Likes.Any(l => l.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value) ? "fas text-danger" : "far text-muted") fa-heart me-1"></i>
                                <span class="small fw-bold like-count">@answer.Likes.Count</span>
                            </button>
                        </div>
                    </div>
                    <div class="answer-body text-white opacity-70 border-start border-primary border-opacity-20 ps-3 py-1 mb-3">
                        @answer.Content
                    </div>
                    <div class="text-end">
                        <div class="extra-small text-muted opacity-40">@answer.CreatedAt.ToString("g")</div>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Response Input Box -->
    <div class="col-lg-4 order-lg-2">
        <div class="sticky-top" style="top: 100px;">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="elegant-card card-pink border-0">
                    <h6 class="font-heading text-white mb-3">Yanıtını Gönder</h6>
                    <p class="extra-small text-muted mb-4 border-bottom border-secondary border-opacity-10 pb-3">Yardımseverliğin sana +10 XP kazandıracak.</p>
                    <form asp-controller="Answers" asp-action="Create" method="post">
                        <input type="hidden" name="QuestionId" value="@Model.Id" />
                        <div class="mb-3">
                            <textarea name="Content" class="form-control small py-3" rows="5" placeholder="Bilgini buraya aktar..." required></textarea>
                        </div>
                        <button type="submit" class="btn-elegant-pink w-100 py-2 shadow-lg">GÖNDER <i class="fas fa-paper-plane ms-2"></i></button>
                    </form>
                </div>
            }
            else
            {
                <div class="elegant-card text-center py-5">
                    <i class="fas fa-sign-in-alt fa-2x mb-3 text-muted opacity-30"></i>
                    <h6 class="text-white opacity-75">Yanıt yazmak için giriş yapmalısın.</h6>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-elegant-cyan btn-sm mt-3 px-4">GİRİŞ YAP</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $(".like-btn").click(function() {
                var btn = $(this);
                var id = btn.data("id");
                
                $.post("/Answers/Like", { answerId: id }, function(data) {
                    if (data.success) {
                        var icon = btn.find("i");
                        icon.toggleClass("fas far text-danger text-muted");
                        btn.find(".like-count").text(data.count);
                        
                        btn.addClass("soft-pulse");
                        setTimeout(() => btn.removeClass("soft-pulse"), 1000);
                    } else if (data.redirect) {
                        window.location.href = data.redirect;
                    }
                });
            });
        });
    </script>
    <style>
        .font-secondary { font-family: 'Inter', sans-serif; }
        .extra-small { font-size: 0.65rem; letter-spacing: 0.5px; }
        .hover-neon:hover { color: var(--neon-cyan) !important; }
    </style>
}

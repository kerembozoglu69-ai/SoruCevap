@model SoruCevap_forum_.Models.ApplicationUser
@{
    ViewData["Title"] = "Profilim";
}

<div class="row mt-5">
    <!-- User Overview Card -->
    <div class="col-lg-4 mb-4">
        <div class="elegant-card text-center card-cyan">
            <div class="position-relative d-inline-block mb-4">
                <div class="bg-dark p-2 rounded-circle border border-secondary border-opacity-20 shadow-lg">
                    <i class="fas fa-user-circle fa-7x text-white opacity-20"></i>
                </div>
                <div class="position-absolute bottom-0 end-0 bg-cyan rounded-circle p-2 shadow-sm" style="width: 35px; height: 35px; border: 3px solid var(--bg-main); background: var(--neon-cyan);">
                    <i class="fas fa-check text-black small"></i>
                </div>
            </div>
            
            <h3 class="font-heading text-white mb-1">@Model.FullName</h3>
            <p class="text-muted small mb-4">@Model.Email</p>
            
            <div class="d-flex justify-content-center gap-2 mb-4">
                <span class="badge badge-neon-cyan px-3 py-2">@Model.Level</span>
                <span class="badge bg-secondary bg-opacity-20 text-white px-3 py-2 border border-secondary border-opacity-10"><i class="fas fa-bolt text-warning me-1"></i> @Model.Points XP</span>
            </div>

            <hr class="border-secondary opacity-10 mb-4">

            <div class="row g-0">
                <div class="col-6 border-end border-secondary border-opacity-10">
                    <h4 class="font-heading text-white mb-0">@Model.Questions.Count</h4>
                    <span class="text-muted extra-small">SORU</span>
                </div>
                <div class="col-6">
                    <h4 class="font-heading text-white mb-0">@Model.Answers.Count</h4>
                    <span class="text-muted extra-small">CEVAP</span>
                </div>
            </div>
        </div>

        <!-- Capability Tiers -->
        <div class="elegant-card mt-4 border-dashed border-secondary border-opacity-20 bg-transparent">
            <h6 class="font-heading text-white small mb-4 opacity-50">KAZANILAN ROZETLER</h6>
            <div class="d-flex flex-wrap gap-2">
                @if (Model.Points >= 100)
                {
                    <div class="bg-secondary bg-opacity-10 p-3 rounded text-center flex-grow-1 border border-secondary border-opacity-10" title="BİLGİN_RANK">
                        <i class="fas fa-medal text-info fa-lg mb-2"></i>
                        <div class="extra-small text-muted fw-bold">BİLGİN</div>
                    </div>
                }
                <div class="bg-secondary bg-opacity-10 p-3 rounded text-center flex-grow-1 border border-secondary border-opacity-10" title="ONAYLI_UYÈ">
                    <i class="fas fa-user-check text-success fa-lg mb-2"></i>
                    <div class="extra-small text-muted fw-bold">ONAYLI</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Activity Timeline -->
    <div class="col-lg-8">
        <div class="elegant-card mb-4 min-vh-70">
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary border-opacity-10 pb-2">
                <h5 class="font-heading neon-glow-text mb-0">AKTİVİTE AKIŞI</h5>
                <ul class="nav nav-pills custom-pills" id="profileTabs" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#my-questions">SORULARIM</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="pill" data-bs-target="#my-answers">CEVAPLARIM</button>
                    </li>
                </ul>
            </div>

            <div class="tab-content mt-4">
                <!-- My Questions -->
                <div class="tab-pane fade show active" id="my-questions">
                    @if (!Model.Questions.Any())
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-folder-open fa-3x mb-3 text-muted opacity-10"></i>
                            <p class="text-muted small opacity-50">// Henüz herhangi bir soru kaydı bulunamadı.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var q in Model.Questions.OrderByDescending(x => x.CreatedAt))
                        {
                            <div class="p-4 mb-3 border-bottom border-secondary border-opacity-10 hover-lift transition-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="font-heading mb-0">
                                        <a asp-controller="Questions" asp-action="Details" asp-route-id="@q.Id" class="text-white text-decoration-none hover-neon">@q.Title</a>
                                    </h6>
                                    <span class="text-muted extra-small">@q.CreatedAt.ToString("d")</span>
                                </div>
                                <p class="text-muted small mb-0 truncate-2 opacity-75">@q.Content</p>
                            </div>
                        }
                    }
                </div>

                <!-- My Answers -->
                <div class="tab-pane fade" id="my-answers">
                    @if (!Model.Answers.Any())
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-quote-right fa-3x mb-3 text-muted opacity-10"></i>
                            <p class="text-muted small opacity-50">// Henüz herhangi bir yanıt kaydı bulunamadı.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var a in Model.Answers.OrderByDescending(x => x.CreatedAt))
                        {
                            <div class="p-4 mb-3 border-bottom border-secondary border-opacity-10 hover-lift transition-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="extra-small font-heading neon-glow-pink">CEVAP: @a.Question?.Title.ToUpper()</span>
                                    <span class="text-muted extra-small">@a.CreatedAt.ToString("d")</span>
                                </div>
                                <p class="small text-white text-opacity-50 mb-0 italic">"> @a.Content"</p>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .hover-neon:hover { color: var(--neon-cyan) !important; text-shadow: var(--glow-cyan); }
        .hover-lift:hover { background: rgba(255, 255, 255, 0.02); border-radius: 12px; transform: scale(1.01); }
        .custom-pills .nav-link { 
            background: transparent; color: var(--text-muted); border-radius: 8px; 
            font-size: 0.75rem; font-weight: 700; margin-left: 10px; padding: 8px 15px; 
        }
        .custom-pills .nav-link.active { background: var(--neon-cyan) !important; color: #000 !important; box-shadow: var(--glow-cyan); }
        .min-vh-70 { min-height: 70vh; }
        .transition-3 { transition: 0.3s; }
        .extra-small { font-size: 0.65rem; }
        .truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    </style>
}
